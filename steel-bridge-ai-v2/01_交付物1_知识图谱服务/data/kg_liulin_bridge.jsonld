      "sb:projectId": "LLQ-2024-001",
      "sb:projectName": "柳林桥钢箱梁建造项目",
      "sb:bridgeType": "中承式拱桥（钢箱梁）",
      "sb:location": "天津市",
      "sb:designUnit": "中交第一航务工程局",
      "sb:manufactureUnit": "一航局",
      "sb:startDate": "2024-01-15",
      "sb:status": "在建",
      "sb:description": "面向AI的模型驱动下钢箱梁模块化设计与生产数据架构研究课题",
      "sb:totalDrawings": 72,
      "sb:mainDrawings": 64,
      "sb:smartBridgeDrawings": 4
    },
    
    {
      "@id": "sb:Substructure_System",
      "@type": "sb:ComponentSystem",
      "sb:systemName": "下部结构系统",
